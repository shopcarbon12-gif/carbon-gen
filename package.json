{
  "name": "carbon-gen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build && node -e \"const fs=require('fs');const path=require('path');const root=process.cwd();const src=path.join(root,'.next','static');const out=path.join(root,'.next','standalone','.next','static');if(fs.existsSync(src)){fs.mkdirSync(out,{recursive:true});fs.cpSync(src,out,{recursive:true,force:true});}const pub=path.join(root,'public');const pubOut=path.join(root,'.next','standalone','public');if(fs.existsSync(pub)){fs.mkdirSync(pubOut,{recursive:true});fs.cpSync(pub,pubOut,{recursive:true,force:true});}console.log('[build] standalone static/public synced');\"",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "dev:raw": "next dev --webpack",
    "dev:3000": "next dev --webpack -p 3000",
    "printer:bridge": "node scripts/local-printer-bridge.mjs",
    "shopify:print-bridge": "node scripts/shopify-print-bridge.mjs",
    "start": "node .next/standalone/server.js -H 0.0.0.0",
    "start:standalone": "node .next/standalone/server.js -H 0.0.0.0",
    "lint": "eslint",
    "hash-password": "node scripts/hash-password.mjs",
    "e2e": "node scripts/run-e2e.mjs",
    "check:upstash": "node scripts/check-upstash.mjs",
    "check:sync": "node scripts/check-sync.mjs",
    "check:shopify": "node scripts/check-shopify-smoke.mjs",
    "start:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-tunnel.ps1",
    "start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-local-stack.ps1",
    "stop:local": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-stack.ps1",
    "backup:restore": "powershell -ExecutionPolicy Bypass -File scripts/create-restore.ps1",
    "empty:storage": "node scripts/empty-storage.mjs",
    "playwright:install": "npx playwright install",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "deploy:coolify": "node scripts/deploy-coolify.mjs",
    "deploy:coolify:setup": "node scripts/setup-coolify-deploy.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.992.0",
    "@google/genai": "^1.42.0",
    "@opennextjs/cloudflare": "^1.16.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@zxing/browser": "^0.1.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "openai": "^6.22.0",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.65.0"
  }
}
